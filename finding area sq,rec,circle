def sq():
    s=int(input("Enter your Side:"))
    print("Area of Square:",s*s)
def cir(r):
    print("Area of Circle:",r*r*3.14)
def rec(a,b):
    print("Area of Rectangle:",a*b)

while True:
    print("1.Square")
    print("2.Circle")
    print("3.Rectangle")
    print("4.Exit")
    choice=int(input("Enter your choice:"))
    
    if choice==1:
        sq()
    elif choice==2:
        cir(20)
    elif choice==3:
        rec(10,20)
    else:
        break
